        2
      ],
      "safe_retry": false
    },
    {
      "id": 4,
      "instance": "tm1srv01",
      "process": "}bedrock.server.wait",
      "parameters": {
        "pWaitSec": "3"
      },
      "predecessors": [
        3
      ],
      "safe_retry": true
    },
    {
      "id": 5,
      "instance": "tm1srv01",
      "process": "}bedrock.server.wait",
      "parameters": {
        "pWaitSec": "3"
      },
      "predecessors": [
        4
      ],
      "safe_retry": true
    }
  ]
