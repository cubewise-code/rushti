{
  "version": "2.0",
  "metadata": {
    "workflow": "checkpoint-resume-test",
    "name": "Checkpoint Resume Test",
    "description": "A simple 5-task sequential pipeline for testing checkpoint and resume functionality. Each task waits 3 seconds."
  },
  "tasks": [
    {
      "id": 1,
      "instance": "tm1srv01",
      "process": "}bedrock.server.wait",
      "parameters": {
        "pWaitSec": "3"
      },
      "safe_retry": true
    },
    {
      "id": 2,
      "instance": "tm1srv01",
      "process": "}bedrock.server.wait",
      "parameters": {
        "pWaitSec": "3"
      },
